    {
      "name": "Concurrency Demo",
      "description": "Newman and Postman collection iterations are sequential, so this harness launches two HTTP POSTs asynchronously from one test script and aggregates both callbacks. The request bodies and target window are identical; idempotency keys differ so they are genuine competing commands.",
      "item": [
        {
          "name": "Parallel race harness — exactly one winner",
          "request": {
            "method": "GET",
            "header": [],
            "url": "{{baseUrl}}/actuator/health/readiness",
            "description": "Runs a readiness request, then launches two identical appointment bodies concurrently with distinct idempotency keys. Exactly one must return 201 and the other 409. Run with one Newman iteration: newman run postman/Unified-Service-Scheduler.postman_collection.json -e postman/Unified-Service-Scheduler.local.postman_environment.json --folder \"Concurrency Demo\" --iteration-count 1 --reporters cli,junit --reporter-junit-export postman/newman-concurrency.xml"
          },
          "response": [],
          "event": [
            {
              "listen": "test",
              "script": {
                "type": "text/javascript",
                "exec": [
                  "pm.test('Harness request status is exactly 200', () => pm.response.to.have.status(200));",
                  "const health = pm.response.json();",
                  "pm.test('Harness readiness body reports UP', () => pm.expect(health).to.have.property('status', 'UP'));",
                  "",
                  "const baseUrl = pm.environment.get('baseUrl');",
                  "const body = {",
                  "  customerId: pm.environment.get('customerId'),",
                  "  vehicleId: pm.environment.get('vehicleId'),",
                  "  dealershipId: pm.environment.get('dealershipId'),",
                  "  serviceTypeId: pm.environment.get('serviceTypeId'),",
                  "  startTime: pm.collectionVariables.get('raceStart')",
                  "};",
                  "const statuses = [];",
                  "const responses = [];",
                  "let completed = 0;",
                  "",
                  "function finish() {",
                  "  completed += 1;",
                  "  if (completed !== 2) return;",
                  "  pm.test('Exactly one parallel booking wins and one is rejected', () => {",
                  "    pm.expect(statuses.filter(s => s === 201).length).to.eql(1);",
                  "    pm.expect(statuses.filter(s => s === 409).length).to.eql(1);",
                  "  });",
                  "  const winner = responses.find(r => r.status === 201).json;",
                  "  const loser = responses.find(r => r.status === 409).json;",
                  "  pm.test('Winning appointment has complete assignment and computed duration', () => {",
                  "    pm.expect(winner).to.include.all.keys('id', 'customer', 'vehicle', 'dealership', 'serviceType', 'technician', 'serviceBay', 'startTime', 'endTime', 'status', 'createdAt');",
                  "    pm.expect(winner.id).to.match(/^[0-9a-f]{8}-[0-9a-f]{4}-[1-5][0-9a-f]{3}-[89ab][0-9a-f]{3}-[0-9a-f]{12}$/i);",
                  "    pm.expect(winner.technician.id).to.match(/^[0-9a-f]{8}-[0-9a-f]{4}-[1-5][0-9a-f]{3}-[89ab][0-9a-f]{3}-[0-9a-f]{12}$/i);",
                  "    pm.expect(winner.serviceBay.id).to.match(/^[0-9a-f]{8}-[0-9a-f]{4}-[1-5][0-9a-f]{3}-[89ab][0-9a-f]{3}-[0-9a-f]{12}$/i);",
                  "    pm.expect(winner.startTime).to.eql(pm.collectionVariables.get('raceStart'));",
                  "    pm.expect(winner.endTime).to.eql(pm.collectionVariables.get('raceEnd'));",
                  "    pm.expect(winner.status).to.eql('CONFIRMED');",
                  "    pm.expect(new Date(winner.endTime).getTime() - new Date(winner.startTime).getTime()).to.eql(Number(pm.environment.get('serviceDurationMinutes')) * 60000);",
                  "  });",
                  "  pm.test('Losing response has the specific concurrency/unavailability problem reason', () => {",
                  "    pm.expect(loser).to.include.all.keys('type', 'title', 'status', 'detail', 'instance', 'code', 'timestamp', 'correlationId');",
                  "    pm.expect(loser.status).to.eql(409);",
                  "    pm.expect(['BOOKING_RACE_LOST', 'BOOKING_CONFLICT']).to.include(loser.code);",
                  "    if (loser.code === 'BOOKING_RACE_LOST') pm.expect(loser.detail).to.eql('A competing request won the booking race');",
                  "    if (loser.code === 'BOOKING_CONFLICT') pm.expect(loser.detail).to.eql('No qualified technician and service bay are available');",
                  "  });",
                  "}",
                  "",
                  "for (let i = 1; i <= 2; i += 1) {",
                  "  pm.sendRequest({",
                  "    url: baseUrl + '/api/v1/appointments',",
                  "    method: 'POST',",
                  "    header: {",
                  "      'Content-Type': 'application/json',",
                  "      'Idempotency-Key': pm.collectionVariables.get('runId') + '-race-' + i,",
                  "      'X-Correlation-ID': 'postman-' + pm.collectionVariables.get('runId') + '-race-' + i",
                  "    },",
                  "    body: { mode: 'raw', raw: JSON.stringify(body) }",
                  "  }, (error, response) => {",
                  "    pm.test('Parallel request ' + i + ' completed without transport error', () => pm.expect(error).to.eql(null));",
                  "    if (!error) {",
                  "      statuses.push(response.code);",
                  "      responses.push({ status: response.code, json: response.json() });",
                  "    }",
                  "    finish();",
                  "  });",
                  "}"
                ]
              }
            }
          ]
        }
      ]
    }
  ]
