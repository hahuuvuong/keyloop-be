                  "});"
                ]
              }
            }
          ]
        }
      ]
    },
    {
      "name": "Availability Conflicts (409)",
      "description": "The implementation exposes one combined BOOKING_CONFLICT reason and automatically assigns resources. With the single-resource dev seed, these prove interval conflicts for the assigned technician and bay together. The API cannot independently target same-technician/different-bay, same-bay/different-technician, or distinguish unqualified from unavailable.",
      "item": [
        {
          "name": "Exact same interval as confirmed appointment",
          "request": {
            "method": "POST",
            "header": [
              {
                "key": "Idempotency-Key",
                "value": "{{runId}}-conflict-exact"
              },
              {
                "key": "X-Correlation-ID",
                "value": "postman-{{runId}}-conflict-exact"
              },
              {
                "key": "Content-Type",
                "value": "application/json"
              }
            ],
            "url": "{{baseUrl}}/api/v1/appointments",
            "description": "Same service and start means the exact same computed [start,end) interval. The implemented detail identifies qualified-technician and service-bay availability together.",
            "body": {
              "mode": "raw",
              "raw": "{\n  \"customerId\": \"{{customerId}}\",\n  \"vehicleId\": \"{{vehicleId}}\",\n  \"dealershipId\": \"{{dealershipId}}\",\n  \"serviceTypeId\": \"{{serviceTypeId}}\",\n  \"startTime\": \"{{happyStart}}\"\n}",
              "options": {
                "raw": {
                  "language": "json"
                }
              }
            }
          },
          "response": [],
          "event": [
            {
              "listen": "test",
              "script": {
                "type": "text/javascript",
                "exec": [
                  "pm.test('Status is exactly 409', () => pm.response.to.have.status(409));",
                  "pm.test('Content-Type is application/problem+json', () => pm.expect(pm.response.headers.get('Content-Type')).to.include('application/problem+json'));",
                  "const problem = pm.response.json();",
                  "pm.test('Problem response has the complete RFC 9457 extension structure', () => {",
                  "  pm.expect(problem).to.include.all.keys('type', 'title', 'status', 'detail', 'instance', 'code', 'timestamp', 'correlationId');",
                  "  pm.expect(problem.status).to.eql(409);",
                  "  pm.expect(problem.code).to.eql('BOOKING_CONFLICT');",
                  "  pm.expect(problem.instance).to.eql('/api/v1/appointments');",
                  "  pm.expect(problem.type).to.match(new RegExp('^https://keyloop[.]example/problems/'));",
                  "  pm.expect(new Date(problem.timestamp).toString()).not.to.eql('Invalid Date');",
                  "  pm.expect(problem.correlationId).to.be.a('string').and.not.empty;",
                  "});",
                  "pm.test('Error detail matches the implemented reason', () => { pm.expect(problem.detail).to.eql('No qualified technician and service bay are available'); pm.expect(problem.detail.toLowerCase()).to.include('qualified technician'); pm.expect(problem.detail.toLowerCase()).to.include('service bay'); });"
                ]
              }
            }
          ]
        },
