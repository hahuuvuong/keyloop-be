  "item": [
    {
      "name": "Setup",
      "description": "The API has no reference-data write endpoints. Docker Compose uses the dev profile and Flyway seeds the IDs in the environment. These requests initialize unique future test times and verify that the clean-database seed is usable.",
      "item": [
        {
          "name": "Initialize run and verify readiness",
          "request": {
            "method": "GET",
            "header": [],
            "url": "{{baseUrl}}/actuator/health/readiness",
            "description": "Resets collection-scoped run variables. Run this first when clicking requests manually. A fresh random future window makes the suite rerunnable without deleting prior appointments."
          },
          "response": [],
          "event": [
            {
              "listen": "prerequest",
              "script": {
                "type": "text/javascript",
                "exec": [
                  "const now = new Date();",
                  "const jitterMs = Math.floor(Math.random() * 3600000);",
                  "const base = new Date(now.getTime() + (8 * 24 * 60 * 60 * 1000) + jitterMs);",
                  "const iso = minutes => new Date(base.getTime() + minutes * 60000).toISOString();",
                  "const runId = 'uss-' + now.getTime() + '-' + Math.random().toString(16).slice(2, 10);",
                  "pm.collectionVariables.set('runId', runId);",
                  "pm.collectionVariables.set('happyStart', iso(0));",
                  "pm.collectionVariables.set('happyEnd', iso(60));",
                  "pm.collectionVariables.set('backToBackStart', iso(60));",
                  "pm.collectionVariables.set('backToBackEnd', iso(120));",
                  "pm.collectionVariables.set('partialLateStart', iso(45));",
                  "pm.collectionVariables.set('partialEarlyStart', iso(-15));",
                  "pm.collectionVariables.set('validationStart', iso(240));",
                  "pm.collectionVariables.set('notFoundStart', iso(360));",
                  "pm.collectionVariables.set('raceStart', iso(600));",
                  "pm.collectionVariables.set('raceEnd', iso(660));",
                  "pm.collectionVariables.set('runInitialized', 'true');"
                ]
              }
            },
            {
              "listen": "test",
              "script": {
                "type": "text/javascript",
                "exec": [
                  "pm.test('Status is exactly 200', () => pm.response.to.have.status(200));",
                  "const health = pm.response.json();",
                  "pm.test('Readiness body reports UP', () => { pm.expect(health).to.have.property('status', 'UP'); });"
                ]
              }
            }
          ]
        },
        {
          "name": "Verify development reference seed is schedulable",
          "request": {
            "method": "GET",
            "header": [],
            "url": "{{baseUrl}}/api/v1/availability?dealershipId={{dealershipId}}&serviceTypeId={{serviceTypeId}}&startTime={{happyStart}}",
            "description": "Confirms the dev seed supplied by R__development_seed.sql contains an active dealership, qualified technician, service bay, and 60-minute service. Customer and vehicle references are verified by the first booking."
          },
          "response": [],
          "event": [
            {
              "listen": "test",
              "script": {
                "type": "text/javascript",
                "exec": [
                  "pm.test('Status is exactly 200', () => pm.response.to.have.status(200));",
                  "pm.test('Content-Type is JSON', () => pm.expect(pm.response.headers.get('Content-Type')).to.include('application/json'));",
                  "const availability = pm.response.json();",
                  "pm.test('Availability response has the exact documented structure', () => {",
                  "  pm.expect(availability).to.have.all.keys('available', 'advisory');",
                  "  pm.expect(availability.available).to.eql(true);",
                  "  pm.expect(availability.advisory).to.eql(true);",
                  "});"
                ]
              }
            }
          ]
        }
      ]
    },
    {
      "name": "Happy Path",
      "item": [
        {
          "name": "Create confirmed appointment",
          "request": {
            "method": "POST",
            "header": [
              {
                "key": "Idempotency-Key",
                "value": "{{runId}}-happy-1"
              },
              {
                "key": "X-Correlation-ID",
                "value": "postman-{{runId}}-happy-1"
              },
              {
                "key": "Content-Type",
                "value": "application/json"
              }
            ],
            "url": "{{baseUrl}}/api/v1/appointments",
            "description": "Creates the baseline confirmed appointment and captures appointmentId, assignedTechnicianId, and assignedBayId as collection variables.",
            "body": {
              "mode": "raw",
              "raw": "{\n  \"customerId\": \"{{customerId}}\",\n  \"vehicleId\": \"{{vehicleId}}\",\n  \"dealershipId\": \"{{dealershipId}}\",\n  \"serviceTypeId\": \"{{serviceTypeId}}\",\n  \"startTime\": \"{{happyStart}}\"\n}",
              "options": {
                "raw": {
                  "language": "json"
                }
              }
            }
          },
          "response": [],
          "event": [
            {
              "listen": "test",
              "script": {
                "type": "text/javascript",
                "exec": [
                  "pm.test('Status is exactly 201', () => pm.response.to.have.status(201));",
                  "pm.test('Content-Type is JSON', () => pm.expect(pm.response.headers.get('Content-Type')).to.include('application/json'));",
                  "const appointment = pm.response.json();",
                  "pm.test('Appointment response has every documented field', () => {",
                  "  pm.expect(appointment).to.include.all.keys('id', 'customer', 'vehicle', 'dealership', 'serviceType', 'technician', 'serviceBay', 'startTime', 'endTime', 'status', 'createdAt');",
                  "  pm.expect(appointment.id).to.match(/^[0-9a-f]{8}-[0-9a-f]{4}-[1-5][0-9a-f]{3}-[89ab][0-9a-f]{3}-[0-9a-f]{12}$/i);",
                  "  ['customer', 'vehicle', 'dealership', 'serviceType', 'technician', 'serviceBay'].forEach(resource => {",
                  "    pm.expect(appointment[resource]).to.include.all.keys('id', 'uri');",
                  "    pm.expect(appointment[resource].id).to.match(/^[0-9a-f]{8}-[0-9a-f]{4}-[1-5][0-9a-f]{3}-[89ab][0-9a-f]{3}-[0-9a-f]{12}$/i);",
                  "    pm.expect(appointment[resource].uri).to.be.a('string').and.not.empty;",
                  "  });",
                  "  pm.expect(appointment.customer.id).to.eql(pm.environment.get('customerId'));",
                  "  pm.expect(appointment.vehicle.id).to.eql(pm.environment.get('vehicleId'));",
                  "  pm.expect(appointment.dealership.id).to.eql(pm.environment.get('dealershipId'));",
                  "  pm.expect(appointment.serviceType.id).to.eql(pm.environment.get('serviceTypeId'));",
                  "  pm.expect(appointment.status).to.eql('CONFIRMED');",
                  "  pm.expect(new Date(appointment.createdAt).toString()).not.to.eql('Invalid Date');",
                  "});",
                  "pm.test('Start and computed end time match the 60-minute service duration', () => {",
                  "  pm.expect(appointment.startTime).to.eql(pm.collectionVariables.get('happyStart'));",
                  "  pm.expect(appointment.endTime).to.eql(pm.collectionVariables.get('happyEnd'));",
                  "  pm.expect(new Date(appointment.endTime).getTime() - new Date(appointment.startTime).getTime()).to.eql(Number(pm.environment.get('serviceDurationMinutes')) * 60000);",
                  "});",
                  "pm.test('Location identifies the returned appointment', () => pm.expect(pm.response.headers.get('Location')).to.match(new RegExp('/api/v1/appointments/' + appointment.id + '$')));",
                  "pm.collectionVariables.set('appointmentId', appointment.id);",
                  "pm.collectionVariables.set('assignedTechnicianId', appointment.technician.id);",
                  "pm.collectionVariables.set('assignedBayId', appointment.serviceBay.id);"
                ]
              }
            }
          ]
        },
        {
          "name": "Get created appointment by ID",
          "request": {
            "method": "GET",
            "header": [],
            "url": "{{baseUrl}}/api/v1/appointments/{{appointmentId}}",
            "description": ""
          },
          "response": [],
          "event": [
            {
              "listen": "test",
              "script": {
                "type": "text/javascript",
                "exec": [
                  "pm.test('Status is exactly 200', () => pm.response.to.have.status(200));",
                  "pm.test('Content-Type is JSON', () => pm.expect(pm.response.headers.get('Content-Type')).to.include('application/json'));",
                  "const appointment = pm.response.json();",
                  "pm.test('Retrieved appointment has every documented field', () => {",
                  "  pm.expect(appointment).to.include.all.keys('id', 'customer', 'vehicle', 'dealership', 'serviceType', 'technician', 'serviceBay', 'startTime', 'endTime', 'status', 'createdAt');",
                  "  pm.expect(appointment.id).to.eql(pm.collectionVariables.get('appointmentId'));",
                  "  pm.expect(appointment.customer.id).to.eql(pm.environment.get('customerId'));",
                  "  pm.expect(appointment.vehicle.id).to.eql(pm.environment.get('vehicleId'));",
                  "  pm.expect(appointment.dealership.id).to.eql(pm.environment.get('dealershipId'));",
                  "  pm.expect(appointment.serviceType.id).to.eql(pm.environment.get('serviceTypeId'));",
                  "  pm.expect(appointment.technician.id).to.eql(pm.collectionVariables.get('assignedTechnicianId'));",
                  "  pm.expect(appointment.serviceBay.id).to.eql(pm.collectionVariables.get('assignedBayId'));",
                  "  pm.expect(appointment.status).to.eql('CONFIRMED');",
                  "});",
                  "pm.test('Retrieved interval and computed duration match the booking', () => {",
                  "  pm.expect(appointment.startTime).to.eql(pm.collectionVariables.get('happyStart'));",
                  "  pm.expect(appointment.endTime).to.eql(pm.collectionVariables.get('happyEnd'));",
                  "  pm.expect(new Date(appointment.endTime).getTime() - new Date(appointment.startTime).getTime()).to.eql(Number(pm.environment.get('serviceDurationMinutes')) * 60000);",
                  "});"
                ]
              }
            }
          ]
        },
