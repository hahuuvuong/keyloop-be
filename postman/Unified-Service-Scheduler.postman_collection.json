{
  "info": {
    "_postman_id": "1d8449ab-773c-4c44-93b7-25d7da4aa9bc",
    "name": "Unified Service Scheduler API — Scenario A",
    "description": "Video-demo and Newman regression collection matched to the implemented Scenario A API. Docker Compose starts the app with the dev profile, whose repeatable Flyway migration seeds the reference IDs in the companion environment. The public API exposes appointment creation/retrieval/listing and advisory availability only; it does not expose reference-data CRUD or caller-selected technician/bay assignment. See postman/README.md for the resulting scenario limitations and the concurrency harness.",
    "schema": "https://schema.getpostman.com/json/collection/v2.1.0/collection.json"
  },
  "event": [
    {
      "listen": "prerequest",
      "script": {
        "type": "text/javascript",
        "exec": [
          "if (pm.collectionVariables.get('runInitialized') !== 'true') {",
          "  const now = new Date();",
          "  const jitterMs = Math.floor(Math.random() * 3600000);",
          "  const base = new Date(now.getTime() + (8 * 24 * 60 * 60 * 1000) + jitterMs);",
          "  const iso = minutes => new Date(base.getTime() + minutes * 60000).toISOString();",
          "  const runId = 'uss-' + now.getTime() + '-' + Math.random().toString(16).slice(2, 10);",
          "  pm.collectionVariables.set('runId', runId);",
          "  pm.collectionVariables.set('happyStart', iso(0));",
          "  pm.collectionVariables.set('happyEnd', iso(60));",
          "  pm.collectionVariables.set('backToBackStart', iso(60));",
          "  pm.collectionVariables.set('backToBackEnd', iso(120));",
          "  pm.collectionVariables.set('partialLateStart', iso(45));",
          "  pm.collectionVariables.set('partialEarlyStart', iso(-15));",
          "  pm.collectionVariables.set('validationStart', iso(240));",
          "  pm.collectionVariables.set('notFoundStart', iso(360));",
          "  pm.collectionVariables.set('raceStart', iso(600));",
          "  pm.collectionVariables.set('raceEnd', iso(660));",
          "  pm.collectionVariables.set('runInitialized', 'true');",
          "}"
        ]
      }
    }
  ],
