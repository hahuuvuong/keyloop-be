<configuration>
  <property name="PATTERN" value="%d{yyyy-MM-dd'T'HH:mm:ss.SSSXXX} level=%level correlationId=%X{correlationId:-none} logger=%logger{36} message=%msg%n"/>
  <appender name="CONSOLE" class="ch.qos.logback.core.ConsoleAppender"><encoder><pattern>${PATTERN}</pattern></encoder></appender>
  <root level="INFO"><appender-ref ref="CONSOLE"/></root>
</configuration>
